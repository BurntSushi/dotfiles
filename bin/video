#!/usr/bin/env bash

. "$HOME/bin/x11-go"

head_num() {
  local head_name="$1"
  gohead tabs | cut -f1-2 | grep "$head_name" | cut -f1
}

place_head() {
  local head_name="$1"
  local monitor
  local x y w h

  monitor="$(head_num "$head_name")"
  IFS=$'\t' read -r x y w h < <(gohead query "$head_name" | cut -f2-5)
  place_monitor "$monitor" "$x" "$y" "$w" "$h"
}

has_arg() {
  local search="$1"
  shift

  local arg
  for arg in "$@"; do
    if [ "$search" = "$arg" ]; then
      return 0
    fi
  done
  return 1
}

start_dzen_workspaces() {
  local monitor="$1"
  local y="$2"

  (
    sleep 1
    "$HOME/.config/wingo/scripts/dzen-workspaces/dzen-workspaces" \
      | dzen2 -dock -xs "$monitor" -h 40 -fn 'Cousine-18' -ta l \
        -bg '#ffffff' -y "$y"
  ) &
}

place_monitor() {
  local monitor="$1"
  local mx="$2"
  local my="$3"
  local mwidth="$4"
  local mheight="$5"
  local height=50
  local font_size=23

  local y=$((mheight - height + my))
  local tray_width=300
  local bat_width=650
  local pager_width
  if is-laptop; then
    pager_width=$((mwidth - bat_width - tray_width))
  else
    pager_width=$((mwidth - tray_width))
  fi

  dzen-wingo-workspaces \
    "$font_size" "$monitor" \
    "$y" "$pager_width" "$height" &
  if is-laptop; then
    dzen-laptop-status \
      "$font_size" "$monitor" \
      "$((mx + pager_width))" "$y" "$height" &
  fi
  my-stalonetray &
}

if ! gohead set "$@" &> /dev/null; then
  exit 1
fi

killall dzen-workspaces &> /dev/null
killall dzen2 &> /dev/null
killall stalonetray &> /dev/null

case "$(myhostname)" in
  duff|frink)
    my-stalonetray &
    start_dzen_workspaces 3 1170
    ;;
  nas2)
    my-stalonetray &
    (
      "$HOME/.config/wingo/scripts/dzen-workspaces/dzen-workspaces" \
        | dzen2 -dock -xs 3 -h 40 -fn 'Cousine-18' -ta l -bg '#ffffff' -y 1170
    ) &
    ;;
  bart|kang)
    if has_arg laptop "$@"; then
      place_head laptop
    else
      place_head "$1"
    fi
    ;;
  flanders|milhouse|wiggum)
    place_head "$1"
    ;;
  otto)
    my-stalonetray &

    head_height="$(gohead query tv | cut -f4)"
    start_dzen_workspaces 2 "$((head_height - 40))"
    ;;
  *)
    echo "Unrecognized machine '$(hostname)'." >&2
    exit 1
    ;;
esac
exit 0
