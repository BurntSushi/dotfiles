#!/usr/bin/env bash

down="$1"
exist="$(findmnt /m 2>&1)"

case "$(myhostname)" in
  nas|nas2)
    echo "cannot mount media on nas; the nas IS the media!" >&2
    exit 1
    ;;
  duff)
    [ $down = down ] && [ -n "$exist" ] && sudo umount /m
    [ $down != down ] && [ -z "$exist" ] && sudo mount nas2:/m /m
    ;;
  flanders|wiggum|milhouse|otto)
    [ $down = down ] && [ -n "$exist" ] && msshfs-readonly down /m
    [ $down != down ] && [ -z "$exist" ] && msshfs-readonly nas2:/m /m
    ;;
  *)
    [[ $down = down ]] && [[ -n "$exist" ]] && msshfs down /m
    [[ $down != down ]] && [[ -z "$exist" ]] && msshfs nas2:/m /m
    ;;
esac
