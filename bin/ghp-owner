#!/usr/bin/env bash

set -e
base="$1"
if [ -z "$base" ]; then
  base="$(git-master-name)"
fi

owner="$(gh repo view --json owner --jq .owner.login)"
name="$(gh repo view --json name --jq .name)"
branch="$(git branch --show-current)"

git push -u origin "$branch"
exec gh pr create \
  --repo "$owner/$name" \
  --fill \
  --base "$base" \
  --head "$owner:$branch"
