#!/bin/sh

battery="$(batrem -s | tr -d '\n')"
if echo "$battery" | rg -q 'AC'; then
  batcolor=77dd77
else
  batcolor=ff6961
fi
nowcolor=3b82ff
font='^fn(Cousine:bold:size=18)'
now="$(biff time fmt now -f "^fg(#$nowcolor)%a, %B %d, %Y, %H:%M %Z")"
exec printf "%s%s  ^fg(#$batcolor)%s\n" "$font" "$now" "$battery"
