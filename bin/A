#!/bin/sh

host="$1"
summary="$2"
body="$3"
if [ -z "$host" ]; then
  host=$(myhostname)
fi
if [ -z "$summary" ]; then
  summary="done"
fi
if [ "$host" = "$(myhostname)" ]; then
  notify-send "$summary" "$body" &
  audio-play /usr/share/sounds/freedesktop/stereo/complete.oga &
  wait
else
  sshrun "$host" A "$host" "$summary" "$body"
fi
