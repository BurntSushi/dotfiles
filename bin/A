#!/usr/bin/env bash

host="$1"
summary="$2"
body="$3"
if [ -z "$host" ] || [ "$host" = "self" ]; then
  host=$(myhostname)
fi
if [ -z "$summary" ]; then
  summary="done"
fi
if [ "$host" = "$(myhostname)" ]; then
  notify-send "$summary" "$body" &
  pw-play /usr/share/sounds/freedesktop/stereo/complete.oga &
  wait
else
  if timeout 2 ssh-add -l &> /dev/null; then
    sshrun "$host" A "$host" "$summary" "$body"
  else
    echo $MY_ALERT_URL
    curl -H "Title: $summary" -d "$body" "$MY_ALERT_URL" &> /dev/null
  fi
fi
